@model IEnumerable<SakilaApp.Models.Rental>
@{
    ViewData["Title"] = "Alquileres";
    var search     = ViewData["Search"] as string ?? "";
    var page       = (int)(ViewData["Page"] ?? 1);
    var total      = (int)(ViewData["Total"] ?? 0);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
}

<div class="page-header">
    <h1><i class="bi bi-calendar-check me-2 text-success"></i>Alquileres</h1>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg me-1"></i>Nuevo alquiler
    </a>
</div>

<div class="search-section">
    <form asp-action="Index" method="get">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" name="search" value="@search" class="form-control border-start-0"
                   placeholder="Buscar por ID de cliente o inventario (número)..." />
            <button type="submit" class="btn btn-success px-4">Buscar</button>
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </div>
    </form>
</div>

<div class="stats-bar px-1">
    @if (!string.IsNullOrWhiteSpace(search))
    {
        <span><i class="bi bi-funnel me-1"></i>@total resultado(s) para ID "<strong>@search</strong>"</span>
    }
    else
    {
        <span><i class="bi bi-calendar-check me-1"></i>@total alquiler(es) en total</span>
    }
    &nbsp;&mdash; Página @(page) de @(totalPages)
</div>

<div class="card-table">
    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th style="width:80px">ID</th>
                <th>Fecha alquiler</th>
                <th>ID Inventario</th>
                <th>ID Cliente</th>
                <th>Fecha devolución</th>
                <th style="width:200px" class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="badge bg-secondary">@item.RentalId</span></td>
                    <td class="small">@item.RentalDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 fw-normal py-1 px-2">
                            @item.InventoryId
                        </span>
                    </td>
                    <td>
                        <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 fw-normal py-1 px-2">
                            @item.CustomerId
                        </span>
                    </td>
                    <td>
                        @if (item.ReturnDate.HasValue)
                        {
                            <span class="badge bg-success"><i class="bi bi-check me-1"></i>@item.ReturnDate.Value.ToString("dd/MM/yyyy")</span>
                        }
                        else
                        {
                            <span class="badge bg-danger"><i class="bi bi-clock me-1"></i>Pendiente</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@item.RentalId" class="btn btn-sm btn-outline-info" title="Ver detalles">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.RentalId" class="btn btn-sm btn-outline-warning" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.RentalId" class="btn btn-sm btn-outline-danger" title="Eliminar">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                        No se encontraron alquileres@(!string.IsNullOrWhiteSpace(search) ? $" para el ID \"{search}\"." : ".")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav aria-label="Paginación" class="mt-3">
        <ul class="pagination justify-content-center flex-wrap">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-page="1">«</a>
            </li>
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-page="@(page - 1)">‹</a>
            </li>
            @{ int from = Math.Max(1, page - 2); int to = Math.Min(totalPages, page + 2); }
            @if (from > 1) { <li class="page-item disabled"><span class="page-link">…</span></li> }
            @for (int p = from; p <= to; p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-page="@p">@p</a>
                </li>
            }
            @if (to < totalPages) { <li class="page-item disabled"><span class="page-link">…</span></li> }
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-page="@(page + 1)">›</a>
            </li>
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-page="@totalPages">»</a>
            </li>
        </ul>
    </nav>
}
