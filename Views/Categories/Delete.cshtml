@model SakilaApp.Models.Category
@{ ViewData["Title"] = "Eliminar categoría"; }

<div class="form-card">
    <div class="card border-danger">
        <div class="card-header bg-danger text-white">
            <h4><i class="bi bi-exclamation-triangle me-2"></i>Confirmar eliminación</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning d-flex align-items-center gap-2">
                <i class="bi bi-info-circle fs-5"></i>
                <span>Esta acción es permanente y no se puede deshacer.</span>
            </div>
            <p class="mb-1"><span class="detail-label">Categoría:</span></p>
            <h5 class="text-danger"><i class="bi bi-tag me-1"></i>@Model.Name</h5>
            <p class="text-muted small mb-0">ID: @Model.CategoryId</p>
        </div>
        <div class="card-footer d-flex gap-2">
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="CategoryId" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>Sí, eliminar
                </button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Cancelar
            </a>
        </div>
    </div>
</div>
