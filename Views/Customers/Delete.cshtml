@model SakilaApp.Models.Customer
@{ ViewData["Title"] = "Desactivar cliente"; }

<div class="form-card">
    <div class="card border-warning">
        <div class="card-header bg-warning text-dark">
            <h4><i class="bi bi-person-dash me-2"></i>Confirmar desactivación</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-info d-flex align-items-center gap-2">
                <i class="bi bi-info-circle fs-5"></i>
                <span>El cliente no se eliminará. Solo se marcará como <strong>inactivo</strong> y dejará de aparecer en la lista.</span>
            </div>
            <p class="mb-1"><span class="detail-label">Cliente:</span></p>
            <h5>@Model.FirstName @Model.LastName</h5>
            <p class="text-muted small mb-0">@Model.Email</p>
        </div>
        <div class="card-footer d-flex gap-2">
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="CustomerId" />
                <button type="submit" class="btn btn-warning text-dark">
                    <i class="bi bi-person-dash me-1"></i>Sí, desactivar
                </button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Cancelar
            </a>
        </div>
    </div>
</div>
