@model SakilaApp.Models.Customer
@{ ViewData["Title"] = "Detalles del cliente"; }

<div class="detail-card">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-person-circle me-2"></i>@Model.FirstName @Model.LastName</h4>
            <span class="badge @(Model.Active ? "bg-success" : "bg-secondary")">
                @(Model.Active ? "Activo" : "Inactivo")
            </span>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-4 detail-label">ID</div>
                <div class="col-8 detail-value">@Model.CustomerId</div>
            </div>
            <hr class="my-2" />
            <div class="row mb-3">
                <div class="col-4 detail-label">Nombre</div>
                <div class="col-8 detail-value">@Model.FirstName</div>
            </div>
            <hr class="my-2" />
            <div class="row mb-3">
                <div class="col-4 detail-label">Apellido</div>
                <div class="col-8 detail-value">@Model.LastName</div>
            </div>
            <hr class="my-2" />
            <div class="row mb-3">
                <div class="col-4 detail-label">Email</div>
                <div class="col-8 detail-value">
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <a href="mailto:@Model.Email">@Model.Email</a>
                    }
                    else { <span class="text-muted">—</span> }
                </div>
            </div>
            <hr class="my-2" />
            <div class="row">
                <div class="col-4 detail-label">Fecha de registro</div>
                <div class="col-8 detail-value text-muted">@Model.CreateDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
        </div>
        <div class="card-footer d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-warning btn-sm">
                <i class="bi bi-pencil me-1"></i>Editar
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>
</div>
