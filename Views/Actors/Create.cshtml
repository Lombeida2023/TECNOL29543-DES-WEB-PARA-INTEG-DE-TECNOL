@model SakilaApp.Models.Actor
@{ ViewData["Title"] = "Nuevo actor"; }

<div class="form-card">
    <div class="card">
        <div class="card-header">
            <h4><i class="bi bi-person-plus me-2"></i>Nuevo actor</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                <div class="mb-3">
                    <label asp-for="FirstName" class="form-label fw-semibold">Nombre</label>
                    <input asp-for="FirstName" class="form-control" placeholder="Ej: PENELOPE" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="LastName" class="form-label fw-semibold">Apellido</label>
                    <input asp-for="LastName" class="form-control" placeholder="Ej: GUINESS" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
                <div class="card-footer px-0 pb-0 pt-3 border-0 bg-transparent d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg me-1"></i>Guardar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
