@model SakilaApp.Models.Actor
@{ ViewData["Title"] = "Detalles del actor"; }

<div class="detail-card">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-person-badge me-2"></i>@Model.FirstName @Model.LastName</h4>
            <span class="badge bg-success">Activo</span>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-4 detail-label">ID</div>
                <div class="col-8 detail-value">@Model.ActorId</div>
            </div>
            <hr class="my-2" />
            <div class="row mb-3">
                <div class="col-4 detail-label">Nombre</div>
                <div class="col-8 detail-value">@Model.FirstName</div>
            </div>
            <hr class="my-2" />
            <div class="row mb-3">
                <div class="col-4 detail-label">Apellido</div>
                <div class="col-8 detail-value">@Model.LastName</div>
            </div>
            <hr class="my-2" />
            <div class="row mb-3">
                <div class="col-4 detail-label">Última actualización</div>
                <div class="col-8 detail-value text-muted">@Model.LastUpdate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            @if (Model.FilmActors != null && Model.FilmActors.Any())
            {
                <hr />
                <h6 class="detail-label mb-3"><i class="bi bi-film me-1"></i>Películas (@Model.FilmActors.Count)</h6>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var fa in Model.FilmActors)
                    {
                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 fw-normal py-2 px-3">
                            @fa.Film?.Title
                        </span>
                    }
                </div>
            }
        </div>
        <div class="card-footer d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.ActorId" class="btn btn-warning btn-sm">
                <i class="bi bi-pencil me-1"></i>Editar
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>
</div>
