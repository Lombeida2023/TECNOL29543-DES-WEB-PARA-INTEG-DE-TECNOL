@model SakilaApp.Models.Film

@{
    ViewData["Title"] = "Editar Película";
}

<h1>Editar Película</h1>

<div style="max-width: 600px;">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="FilmId" />

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Título</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ReleaseYear" class="form-label">Año</label>
            <input asp-for="ReleaseYear" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label">Descripción</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="LanguageId" class="form-label">ID de Idioma</label>
            <input asp-for="LanguageId" class="form-control" type="number" />
        </div>

        <div class="mb-3">
            <label asp-for="RentalDuration" class="form-label">Duración de alquiler (días)</label>
            <input asp-for="RentalDuration" class="form-control" type="number" />
        </div>

        <div class="mb-3">
            <label asp-for="RentalRate" class="form-label">Tarifa de alquiler ($)</label>
            <input asp-for="RentalRate" class="form-control" type="number" step="0.01" />
        </div>

        <div class="mb-3">
            <label asp-for="Length" class="form-label">Duración (minutos)</label>
            <input asp-for="Length" class="form-control" type="number" />
        </div>

        <div class="mb-3">
            <label asp-for="ReplacementCost" class="form-label">Costo de reposición ($)</label>
            <input asp-for="ReplacementCost" class="form-control" type="number" step="0.01" />
        </div>

        <div class="mb-3">
            <label asp-for="Rating" class="form-label">Calificación</label>
            <select asp-for="Rating" class="form-select">
                <option value="">-- Seleccionar --</option>
                <option value="G">G</option>
                <option value="PG">PG</option>
                <option value="PG-13">PG-13</option>
                <option value="R">R</option>
                <option value="NC-17">NC-17</option>
            </select>
        </div>

        <button type="submit" class="btn btn-warning">Guardar cambios</button>
        <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}