@model IEnumerable<SakilaApp.Models.Film>

@{
    ViewData["Title"] = "Películas de Sakila";
    var search   = ViewData["Search"] as string ?? "";
    var page     = (int)(ViewData["Page"] ?? 1);
    var total    = (int)(ViewData["Total"] ?? 0);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-primary">+ Nueva película</a>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@search" class="form-control"
               placeholder="Buscar por título, calificación o año..." />
        <button type="submit" class="btn btn-outline-secondary">Buscar</button>
        @if (!string.IsNullOrWhiteSpace(search))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Limpiar</a>
        }
    </div>
</form>

<div class="d-flex justify-content-between align-items-center mb-2">
    <small class="text-muted">
        @if (!string.IsNullOrWhiteSpace(search))
        {
            <span>@total resultado(s) para "<strong>@search</strong>"</span>
        }
        else
        {
            <span>@total película(s) en total</span>
        }
        &nbsp;— Página @(page) de @(totalPages)
    </small>
</div>

<table class="table table-striped table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Título</th>
            <th>Año</th>
            <th>Calificación</th>
            <th>Tarifa</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var film in Model)
        {
            <tr>
                <td>@film.FilmId</td>
                <td>@film.Title</td>
                <td>@film.ReleaseYear</td>
                <td><span class="badge bg-secondary">@film.Rating</span></td>
                <td>$@film.RentalRate</td>
                <td>
                    <a asp-action="Details" asp-route-id="@film.FilmId" class="btn btn-sm btn-info">Ver</a>
                    <a asp-action="Edit" asp-route-id="@film.FilmId" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Delete" asp-route-id="@film.FilmId" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted py-3">
                    No se encontraron películas@(!string.IsNullOrWhiteSpace(search) ? $" para \"{search}\"." : ".")
                </td>
            </tr>
        }
    </tbody>
</table>

@if (totalPages > 1)
{
    <nav aria-label="Paginación de películas">
        <ul class="pagination justify-content-center flex-wrap">

            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-search="@search" asp-route-page="1">«</a>
            </li>
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-search="@search" asp-route-page="@(page - 1)">‹</a>
            </li>

            @{
                int from = Math.Max(1, page - 2);
                int to   = Math.Min(totalPages, page + 2);
            }

            @if (from > 1)
            {
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }

            @for (int p = from; p <= to; p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-search="@search" asp-route-page="@p">@p</a>
                </li>
            }

            @if (to < totalPages)
            {
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }

            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-search="@search" asp-route-page="@(page + 1)">›</a>
            </li>
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-search="@search" asp-route-page="@totalPages">»</a>
            </li>

        </ul>
    </nav>
}