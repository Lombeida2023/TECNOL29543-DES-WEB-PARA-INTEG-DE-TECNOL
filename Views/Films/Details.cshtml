@model SakilaApp.Models.Film

@{
    ViewData["Title"] = "Detalle de Película";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">🎬 @Model.Title</h4>
                <span class="badge bg-warning text-dark fs-6">@Model.Rating</span>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <strong>🆔 ID:</strong> @Model.FilmId
                            </li>
                            <li class="list-group-item">
                                <strong>📅 Año:</strong> @Model.ReleaseYear
                            </li>
                            <li class="list-group-item">
                                <strong>⏱️ Duración:</strong> @(Model.Length ?? 0) minutos
                            </li>
                            <li class="list-group-item">
                                <strong>🎭 Calificación:</strong>
                                <span class="badge bg-secondary">@Model.Rating</span>
                            </li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <strong>💵 Tarifa de alquiler:</strong> $@Model.RentalRate
                            </li>
                            <li class="list-group-item">
                                <strong>📦 Costo de reposición:</strong> $@Model.ReplacementCost
                            </li>
                            <li class="list-group-item">
                                <strong>📆 Días de alquiler:</strong> @Model.RentalDuration días
                            </li>
                        </ul>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mt-3 p-3 bg-light rounded">
                        <strong>📝 Descripción:</strong>
                        <p class="mt-2 mb-0">@Model.Description</p>
                    </div>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.FilmId" class="btn btn-warning">✏️ Editar</a>
                <a asp-action="Delete" asp-route-id="@Model.FilmId" class="btn btn-danger">🗑️ Eliminar</a>
                <a asp-action="Index" class="btn btn-secondary">← Volver al listado</a>
            </div>
        </div>
    </div>
</div>