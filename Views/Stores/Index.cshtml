@model IEnumerable<SakilaApp.Models.Store>
@{ ViewData["Title"] = "Tiendas"; }

<div class="page-header">
    <h1><i class="bi bi-shop me-2 text-danger"></i>Tiendas</h1>
    <a asp-action="Create" class="btn btn-danger">
        <i class="bi bi-plus-lg me-1"></i>Nueva tienda
    </a>
</div>

<div class="card-table">
    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th style="width:80px">ID</th>
                <th>ID Gerente</th>
                <th>ID Dirección</th>
                <th style="width:160px">Última actualización</th>
                <th style="width:200px" class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="badge bg-danger">Tienda @item.StoreId</span></td>
                    <td>
                        <span class="badge bg-secondary fw-normal py-2 px-3">
                            <i class="bi bi-person-gear me-1"></i>Staff #@item.ManagerStaffId
                        </span>
                    </td>
                    <td>
                        <span class="badge bg-light text-dark border fw-normal py-2 px-3">
                            <i class="bi bi-geo-alt me-1"></i>Dir. #@item.AddressId
                        </span>
                    </td>
                    <td class="text-muted small">@item.LastUpdate.ToString("dd/MM/yyyy")</td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@item.StoreId" class="btn btn-sm btn-outline-info" title="Ver detalles">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.StoreId" class="btn btn-sm btn-outline-warning" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.StoreId" class="btn btn-sm btn-outline-danger" title="Eliminar">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                        No hay tiendas registradas.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
