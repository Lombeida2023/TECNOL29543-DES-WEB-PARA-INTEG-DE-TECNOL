@model SakilaApp.Models.Store
@{ ViewData["Title"] = "Nueva tienda"; }

<div class="form-card">
    <div class="card">
        <div class="card-header">
            <h4><i class="bi bi-shop me-2"></i>Nueva tienda</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                <div class="mb-3">
                    <label asp-for="ManagerStaffId" class="form-label fw-semibold">ID del Gerente (Staff)</label>
                    <input asp-for="ManagerStaffId" class="form-control" placeholder="Ej: 1" />
                    <span asp-validation-for="ManagerStaffId" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="AddressId" class="form-label fw-semibold">ID de Dirección</label>
                    <input asp-for="AddressId" class="form-control" placeholder="Ej: 1" />
                    <span asp-validation-for="AddressId" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg me-1"></i>Guardar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
